{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the exam client",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-always-on-top",
    {
      "identifier": "core:event:allow-listen",
      "allow": [{ "event": "exit-request" }]
    }
  ],
  "remote_domains": [""]
}