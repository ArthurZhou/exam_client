{
  "name": "exam_client",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:osd && vite",
    "build:osd": "esbuild src/main.ts --bundle --minify --format=iife --platform=browser --outfile=dist/main.js --loader:.html=text",
